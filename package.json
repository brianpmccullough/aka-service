{
  "name": "aka-service",
  "version": "1.0.0",
  "description": "aka-service is a planned NestJS service for short and vanity URLs.",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"{src,test}/**/*.{ts,json}\" \"*.{js,json,md,mjs,ts}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"{src,test}/**/*.{ts,json}\" \"*.{js,json,md,mjs,ts}\" \"docs/**/*.md\"",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianpmccullough/aka-service.git"
  },
  "keywords": [],
  "author": "",
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "multer": "2.2.0"
  },
  "bugs": {
    "url": "https://github.com/brianpmccullough/aka-service/issues"
  },
  "homepage": "https://github.com/brianpmccullough/aka-service#readme",
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
